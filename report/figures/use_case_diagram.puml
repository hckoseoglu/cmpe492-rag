@startuml use_case_diagram
left to right direction
skinparam packageStyle rectangle

actor "End User" as EU
actor "Researcher" as R

rectangle "RAG Personal Trainer System" {
    usecase "Ask fitness question" as UC1
    usecase "Request workout program" as UC2
    usecase "Maintain conversation history" as UCH

    usecase "Evaluate chunking strategy" as UC3
    usecase "Evaluate reranker" as UC4
    usecase "Evaluate concept normalization" as UC5
    usecase "Create dataset with\northogonal topics" as UC6
    usecase "Run MTEB retrieval task" as UC7
    usecase "Test knowledge leakage\nwith lexical obfuscation" as UC8
}

EU --> UC1
EU --> UC2
UC1 ..> UCH : <<extend>>
UC2 ..> UCH : <<extend>>

R --> UC3
R --> UC4
R --> UC5
R --> UC6
R --> UC7
R --> UC8
@enduml
